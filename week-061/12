import pandas as pd
from pgmpy.models import DiscreteBayesianNetwork
from pgmpy.estimators import MaximumLikelihoodEstimator
from pgmpy.inference import VariableElimination

data = pd.DataFrame([
    {'StudyHours': 1, 'Understanding': 1, 'PassExam': 1},
    {'StudyHours': 1, 'Understanding': 1, 'PassExam': 1},
    {'StudyHours': 1, 'Understanding': 0, 'PassExam': 0},
    {'StudyHours': 0, 'Understanding': 1, 'PassExam': 0},
    {'StudyHours': 0, 'Understanding': 0, 'PassExam': 0},
    {'StudyHours': 0, 'Understanding': 0, 'PassExam': 0},
])

model = DiscreteBayesianNetwork([
    ('StudyHours', 'Understanding'),
    ('Understanding', 'PassExam')
])

model.fit(data, estimator=MaximumLikelihoodEstimator)

inference = VariableElimination(model)

result = inference.query(variables=['PassExam'], evidence={'StudyHours': 1})

print(result)//
