# Step 0: Import Libraries
import pandas as pd
import numpy as np
from pgmpy.models import BayesianNetwork
from pgmpy.estimators import MaximumLikelihoodEstimator
from pgmpy.inference import VariableElimination

# Step 1: Define Dataset
# 1 = Yes, 0 = No
data = pd.DataFrame([
    {'Rain': 1, 'TrafficJam': 1, 'ArriveLate': 1},
    {'Rain': 1, 'TrafficJam': 1, 'ArriveLate': 0},
    {'Rain': 1, 'TrafficJam': 0, 'ArriveLate': 0},
    {'Rain': 0, 'TrafficJam': 1, 'ArriveLate': 1},
    {'Rain': 0, 'TrafficJam': 0, 'ArriveLate': 0},
    {'Rain': 0, 'TrafficJam': 0, 'ArriveLate': 0},
])

print("Dataset:\n", data)

# Step 2: Define Bayesian Network Structure (DAG)
model = BayesianNetwork([
    ('Rain', 'TrafficJam'),
    ('TrafficJam', 'ArriveLate')
])

print("\nBayesian Network Structure Created")

# Step 3: Parameter Learning using MLE
model.fit(data, estimator=MaximumLikelihoodEstimator)

print("\nModel Trained Successfully")

# Step 4: Display Conditional Probability Distributions (CPDs)
print("\nCPDs:\n")
for cpd in model.get_cpds():
    print(cpd)
    print("-" * 50)

# Step 5: Initialize Inference Engine
inference = VariableElimination(model)

# Step 6: Perform Query
# P(ArriveLate | Rain = Yes)
result = inference.query(variables=['ArriveLate'], evidence={'Rain': 1})

# Step 7: Display Results
print("\nQuery Result: P(ArriveLate | Rain = Yes)\n")
print(result)

# Interpretation
print("\nInterpretation:")
print("If it is raining, this shows the probability of arriving late.")
